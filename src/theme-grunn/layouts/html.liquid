<!DOCTYPE html>
<html
  lang="en"
  x-data="{ darkMode: localStorage.getItem('themeDarkMode') == 'true' }"
  x-init="$watch('darkMode', val => localStorage.setItem('themeDarkMode', val))"
  x-bind:class="{ 'dark': darkMode }"
  class="scroll-smooth"
>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="generator" content="{{ eleventy.generator }}">
    {% comment %}
    <link rel=“preload” href=“/assets/fonts/Tanker-Regular.woff2” as=“font” type=“font/woff2” crossorigin>
    {% endcomment %}

    {{ verification.header  }}

    {% comment %}Mastodon {% endcomment %}
    {%- if verification.mastodon_verification %}
      <link rel="me" href="{{ verification.mastodon_verification }}">
    {% endif -%}

    {% comment %} Github {% endcomment %}
    {%- if verification.github_verification %}
      <link rel="me" href="{{ verification.github_verification }}">
    {% endif =%}

    {% comment %}pinterest {% endcomment %}
    {%- if verification.pinterest_verification %}
      <meta name="p:domain_verify" content="{{ verification.pinterest_verification }}" />
    {% endif -%}

    {% comment %} SEO {% endcomment %}
    {% assign seocanonical = page.url | prepend: env.url  %}
    {% assign seodescription = seo.description | default: site.description  %}
    {%- render "_system/head/seo.liquid",
        canonical: seocanonical,
        description: seodescription,
        seo: seo
    -%}

    <meta name="theme-color" content="{{ site.color }}">

    {%- render "_system/head/icon.liquid", icon: site.icon -%}

    {% comment %}
      OPENGRAPH - get the defined image OR get a screenshot (https://www.11ty.dev/docs/services/screenshots/)
    {% endcomment %}
    {% assign getogTitle = opengraph.title | default: title  %}
    {% assign getogText =  opengraph.description | default: site.description %}
    {% assign getOGurl = page.url | prepend : env.url %}
    {% if opengraph.image or site.opengraph %}

      {% assign getogImage = opengraph.image | default: site.opengraph %}

      {% capture getimageurl %}
        {% render 'image/imageurl.liquid', file: getogImage, widths: "1200",format: "webp" %}
      {% endcapture %}

      {% assign url = env.url  %}
      {% assign ogImage = getimageurl | strip | prepend: url %}

    {% else %}

      {%- capture ogImage -%}
        https://v1.screenshot.11ty.dev/{{env.url | url_encode }}{{page.url | url_encode}}/opengraph/smaller
      {%- endcapture =%}

    {% endif %}

    {%- render "_system/head/opengraph.liquid",
      title: getogTitle,
      description: getogText,
      image: ogImage,
      pageurl: getOGurl,
      site: site,
      env: env,
      some: some
    -%}

    {% comment %} netlify identity
    <script type="text/javascript" src="https://identity.netlify.com/v1/netlify-identity-widget.js" defer></script>
  {% endcomment %}

  {%- if env.mode == 'prod' %}
    <link href="{{ '/assets/css/style.min.css' | url }}" rel="stylesheet">
    {% else %}
    <link href="{{ '/assets/css/style.css' | url }}" rel="stylesheet">
    {% endif -%}

    {% comment %}title {% endcomment %}
    {% if page.url == "/" %}
      <title>{{ seo.title | default: site.title }}</title>
    {% else %}
      <title>{{ seo.title | default: title }} | {{ site.title }}</title>
    {% endif %}

  </head>

  {{ content }}

  {% comment %}Service worker{% endcomment %}
  <script>
    if (navigator && navigator.serviceWorker) {
      navigator
        .serviceWorker
        .register('/service-workers.js');
    }
  </script>

  <script src="/assets/js/alpine3.10.3.min.js" defer></script>
  <script src="/assets/js/alpine-persist.min.js" defer></script>

  </body>
</html>
